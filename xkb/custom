partial alphanumeric_keys
xkb_symbols "custom" {

    // include everything from the normal US layout
    include "us(basic)"

    // Remap Caps Lock to tilde (~)
    key <CAPS> { [ asciitilde, grave ] };

    // Disable the original tilde key (`~`/`` ` `` on US keyboards)
    key <TLDE> { [ NoSymbol, NoSymbol ] };
};
